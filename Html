<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Taurus Obfuscator v1.0.5</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #0c0c0e;
            color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 1050px;
            background: rgba(18, 18, 24, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
            overflow: hidden;
        }

        .header {
            background: rgba(25, 25, 35, 0.4);
            padding: 24px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .header h1 {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 2px;
            color: #ffffff;
            text-shadow: 0 0 12px rgba(0, 150, 100, 0.3);
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            padding: 30px;
        }

        @media (max-width: 850px) {
            .main-content {
                grid-template-columns: 1fr;
            }
        }

        .pane {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .pane-title-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .pane-title {
            font-size: 0.75rem;
            font-weight: 700;
            color: #94a3b8;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Editor Frame setup */
        .editor-container {
            position: relative;
            width: 100%;
            height: 260px;
            background: #13131a;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .editor-container.output-height {
            height: 335px;
        }

        /* Strict Character Alignment Core Rules */
        .input-box, .output-box, .editor-highlight {
            position: absolute !important;
            top: 0 !important;
            left: 0 !important;
            width: 100% !important;
            height: 100% !important;
            margin: 0 !important;
            padding: 14px !important;
            font-family: 'Consolas', 'Courier New', Courier, monospace !important;
            font-size: 14px !important;
            line-height: 22px !important;
            white-space: pre-wrap !important;
            word-wrap: break-word !important;
            word-break: break-all !important;
            box-sizing: border-box !important;
            text-rendering: optimizeLegibility !important;
            -webkit-font-smoothing: antialiased !important;
            letter-spacing: normal !important;
        }

        textarea {
            background: transparent !important;
            border: none !important;
            outline: none !important;
            resize: none !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
        }

        textarea.input-box {
            color: transparent !important;
            caret-color: #00ffaa !important;
            z-index: 2;
        }

        textarea.output-box {
            color: transparent !important;
            caret-color: transparent !important;
            z-index: 2;
        }

        .editor-highlight {
            color: #cbd5e1;
            pointer-events: none;
            z-index: 1;
            overflow: hidden;
        }

        input[type="text"] {
            width: 100%;
            background: #13131a;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            color: #ffffff;
            padding: 14px;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .editor-container:focus-within {
            border-color: #009664;
            box-shadow: 0 0 10px rgba(0, 150, 100, 0.15);
        }

        input[type="text"]:focus {
            border-color: #009664;
            box-shadow: 0 0 10px rgba(0, 150, 100, 0.15);
        }

        /* Syntax Theme Palettes */
        .lua-keyword { color: #ff4a88; font-weight: bold; }
        .lua-builtin { color: #00d0ff; }
        .lua-string  { color: #e1b12c; }
        .lua-number  { color: #9c88ff; }
        .lua-comment { color: #6272a4; font-style: italic; }
        .lua-fncall  { color: #4cd137; }

        .status-label {
            text-align: center;
            font-style: italic;
            font-size: 0.85rem;
            color: #64748b;
            min-height: 20px;
        }

        .btn {
            width: 100%;
            background: #009664;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            padding: 15px;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
        }

        .btn:hover {
            background: #00b075;
        }

        .btn:active {
            transform: scale(0.99);
        }

        .btn-copy {
            background: rgba(255, 255, 255, 0.08);
            color: #e2e8f0;
            padding: 6px 12px;
            font-size: 0.75rem;
            border-radius: 6px;
            width: auto;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .btn-copy:hover {
            background: rgba(255, 255, 255, 0.15);
            color: #ffffff;
        }

        .notification {
            position: fixed;
            bottom: 20px;
            right: -350px;
            width: 320px;
            padding: 16px 20px;
            border-radius: 10px;
            color: #fff;
            font-weight: 600;
            font-size: 0.9rem;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            transition: right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            align-items: center;
            z-index: 1000;
        }

        .notification.show {
            right: 20px;
        }

        .notification.success {
            background: #009664;
            border-left: 5px solid #00ffaa;
        }

        .notification.error {
            background: #a82525;
            border-left: 5px solid #ff4a4a;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <h1>TAURUS OBFUSCATOR v1.0.5</h1>
        </div>
        
        <div class="main-content">
            <div class="pane">
                <span class="pane-title">Source Script Input</span>
                <div class="editor-container">
                    <textarea id="sourceInput" class="input-box" placeholder="-- Paste your source script here..." spellcheck="false"></textarea>
                    <div id="sourceHighlight" class="editor-highlight"></div>
                </div>
                
                <input type="text" id="varInput" placeholder="Custom Variable Prefix (Default: Taurus_)">
                <input type="text" id="wmInput" placeholder="Custom Watermark Text">
                
                <div id="statusLabel" class="status-label">Ready to secure.</div>
                <button id="obfuscateBtn" class="btn">Obfuscate &amp; Process Script</button>
            </div>

            <div class="pane">
                <div class="pane-title-container">
                    <span class="pane-title">Obfuscated Source Output</span>
                    <button id="copyBtn" class="btn btn-copy">Copy Output</button>
                </div>
                <div class="editor-container output-height">
                    <textarea id="outputBox" class="output-box" placeholder="-- Obfuscated output code will appear here..." readonly spellcheck="false"></textarea>
                    <div id="outputHighlight" class="editor-highlight" style="color: #b4dcb4;"></div>
                </div>
            </div>
        </div>
    </div>

    <div id="toastNotification" class="notification"></div>

    <script>
        function highlightLua(code) {
            // Force tracking of double character groupings at lines end
            if (code.endsWith("\n")) {
                code += " ";
            }

            let escaped = code
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");

            const rules = [
                { type: 'comment', regex: /(--\[\[[\s\S]*?\]\]|--.*)/g },
                { type: 'string',  regex: /("(?:\\.|[^"\\])*"|'(?:\\.|[^'\\])*')/g },
                { type: 'number',  regex: /\b(0x[0-9a-fA-F]+|\d+(?:\.\d+)?)\b/g },
                { type: 'keyword', regex: /\b(local|function|return|end|if|then|else|elseif|for|while|do|in|repeat|until|break|true|false|nil)\b/g },
                { type: 'builtin', regex: /\b(game|workspace|script|task|Instance|Vector3|CFrame|Color3|TweenService|HttpService|Players)\b/g },
                { type: 'fncall',  regex: /\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\s*\()/g }
            ];

            let matches = [];
            rules.forEach(rule => {
                let match;
                rule.regex.lastIndex = 0; 
                while ((match = rule.regex.exec(escaped)) !== null) {
                    matches.push({
                        start: match.index,
                        end: match.index + match[0].length,
                        text: match[0],
                        type: rule.type
                    });
                }
            });

            matches.sort((a, b) => a.start - b.start);
            let cleanMatches = [];
            let lastIndex = 0;

            for (let i = 0; i < matches.length; i++) {
                if (matches[i].start >= lastIndex) {
                    cleanMatches.push(matches[i]);
                    lastIndex = matches[i].end;
                }
            }

            let finalHTML = "";
            let currentIndex = 0;

            cleanMatches.forEach(match => {
                finalHTML += escaped.substring(currentIndex, match.start);
                finalHTML += `<span class="lua-${match.type}">${match.text}</span>`;
                currentIndex = match.end;
            });
            finalHTML += escaped.substring(currentIndex);

            return finalHTML;
        }

        const sourceInput = document.getElementById("sourceInput");
        const sourceHighlight = document.getElementById("sourceHighlight");
        const outputBox = document.getElementById("outputBox");
        const outputHighlight = document.getElementById("outputHighlight");

        sourceInput.addEventListener("input", () => {
            sourceHighlight.innerHTML = highlightLua(sourceInput.value);
        });
        
        // Pixel perfect structural scroll synchronization loops
        sourceInput.addEventListener("scroll", () => {
            sourceHighlight.scrollTop = sourceInput.scrollTop;
            sourceHighlight.scrollLeft = sourceInput.scrollLeft;
        });
        outputBox.addEventListener("scroll", () => {
            outputHighlight.scrollTop = outputBox.scrollTop;
            outputHighlight.scrollLeft = outputBox.scrollLeft;
        });

        function showNotification(message, type) {
            const toast = document.getElementById("toastNotification");
            toast.innerText = message;
            toast.className = `notification ${type} show`;
            
            setTimeout(() => {
                toast.classList.remove("show");
            }, 4000);
        }

        function modf(number) {
            return [Math.trunc(number), number % 1];
        }

        function stringToBinary(str) {
            let binaryString = [];
            for (let i = 0; i < str.length; i++) {
                let binary = "";
                let byte = str.charCodeAt(i);
                while (byte > 0) {
                    binary = (byte % 2).toString() + binary;
                    byte = modf(byte / 2)[0];
                }
                binaryString.push(binary.padStart(8, '0'));
            }
            return binaryString.join(" ");
        }

        function random_(length) {
            const letters = ["a","b","c","d","e","f","g","h","i","j","k","l","m","n","o","p","q","r","s","t","u","v","w","x","y","z"];
            let code = "";

            if (Math.random() > 0.5) {
                code += letters[Math.floor(Math.random() * 26)];
            } else {
                code += letters[Math.floor(Math.random() * 26)].toUpperCase();
            }

            for (let i = 0; i < length; i++) {
                if (Math.random() > 0.5) {
                    let letter = letters[Math.floor(Math.random() * 26)];
                    code += Math.random() > 0.5 ? letter.toUpperCase() : letter;
                } else {
                    code += Math.floor(Math.random() * 10).toString();
                }
            }
            return code;
        }

        function add_binary(number, variable) {
            let s = "";
            const topic = [
                "Deobfuscate?",
                "Hello World!",
                "IronBrew Fork? Nope.",
                "PSU Fork? Nope.",
                "Touch some grass",
                "New update when?",
                "GhostyDuckyy",
                "Free obfuscator!",
                "E",
                random_(Math.floor(Math.random() * (150 - 50 + 1)) + 50)
            ];

            for (let i = 0; i < number; i++) {
                let randomTopic = topic[Math.floor(Math.random() * topic.length)];
                let str = "local " + variable + random_(Math.floor(Math.random() * (12 - 10 + 1)) + 10) + " = \"" + stringToBinary(randomTopic) + "\"; ";
                s += str;
            }
            return s;
        }

        function obfuscate(source, varName, waterMark) {
            const variable = varName.trim() !== "" ? varName.trim() : "Taurus_";
            let wm = waterMark.trim() !== "" ? waterMark.trim() : "WaterMark";
            
            if (source.trim() === "") {
                source = 'print("Hello World!")';
            }

            const startTime = performance.now();
            const fullWM = `--[[\n    ${wm}\n]]--\n\n`;

            const randomVarTableByte = random_(Math.floor(Math.random() * (20 - 15 + 1)) + 15);
            const randomVarLoadstring = random_(Math.floor(Math.random() * (20 - 15 + 1)) + 15);

            const trollFunc = `function() ${add_binary(Math.floor(Math.random() * (50 - 30 + 1)) + 30, variable)} end`;
            const trollVar = `local ${variable}${random_(Math.floor(Math.random() * (20 - 15 + 1)) + 15)} = ${trollFunc}`;

            let sourceByte = "";
            for (let i = 0; i < source.length; i++) {
                sourceByte += `"\\${source.charCodeAt(i)}", `;
            }

            const tableByte = `local ${variable}${randomVarTableByte} = {${sourceByte}}`;
            const loadstringBlock = `local ${variable}${randomVarLoadstring} = loadstring(table.concat({"\\114", "\\101", "\\116", "\\117", "\\110", "\\32", "\\102", "\\117", "\\110", "\\99", "\\116", "\\105", "\\110", "\\40", "\\98", "\\121", "\\116", "\\101", "\\41", "\\10", "\\32", "\\32", "\\32", "\\32", "\\105", "\\102", "\\32", "\\116", "\\121", "\\112", "\\101", "\\111", "\\40", "\\98", "\\121", "\\116", "\\101", "\\41", "\\32", "\\61", "\\61", "\\32", "\\34", "\\116", "\\97", "\\98", "\\108", "\\101", "\\34", "\\32", "\\116", "\\104", "\\101", "\\110", "\\10", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\108", "\\111", "\\97", "\\100", "\\115", "\\116", "\\114", "\\105", "\\110", "\\103", "\\40", "\\116", "\\97", "\\98", "\\108", "\\101", "\\46", "\\99", "\\111", "\\110", "\\99", "\\97", "\\116", "\\40", "\\98", "\\121", "\\116", "\\101", "\\41", "\\41", "\\40", "\\41", "\\10", "\\32", "\\32", "\\32", "\\32", "\\101", "\\108", "\\115", "\\101", "\\10", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\98", "\\121", "\\116", "\\101", "\\32", "\\61", "\\32", "\\123", "\\98", "\\121", "\\116", "\\101", "\\125", "\\10", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\32", "\\108", "\\111", "\\97", "\\100", "\\115", "\\116", "\\114", "\\105", "\\110", "\\103", "\\40", "\\116", "\\97", "\\98", "\\108", "\\101", "\\46", "\\99", "\\111", "\\110", "\\99", "\\97", "\\116", "\\40", "\\98", "\\121", "\\116", "\\101", "\\41", "\\41", "\\40", "\\41", "\\10", "\\32", "\\32", "\\32", "\\32", "\\101", "\\110", "\\100", "\\10", "\\101", "\\110", "\\100", "\\10",}))()`;

            const fake_code = function(number, r) {
                let t = [];
                for (let i = 0; i < number; i++) {
                    let createVar = variable + random_(Math.floor(Math.random() * (20 - 15 + 1)) + 15);
                    let randomLength = r !== null ? r : Math.max(1000, Math.floor(source.length / 2));
                    let randomString = "return " + random_(randomLength);

                    let byteStr = "";
                    for (let x = 0; x < randomString.length; x++) {
                        byteStr += `"\\${randomString.charCodeAt(x)}", `;
                    }
                    let fake = `local ${createVar} = {${byteStr}}; local ${createVar} = ${variable}${randomVarLoadstring}(${createVar}); `;
                    t.push(fake);
                }
                return t.join("");
            };

            const part1 = fake_code(Math.floor(Math.random() * (4 - 2 + 1)) + 2, Math.floor(Math.random() * (600 - 400 + 1)) + 400);
            const part2 = fake_code(Math.floor(Math.random() * (4 - 2 + 1)) + 2, Math.floor(Math.random() * ((source.length * 2) - (source.length / 2) + 1)) + (source.length / 2));

            const obfuscated = `${fullWM}${trollVar}; ${loadstringBlock}; ${part1}${tableByte}; local ${variable}${random_(Math.floor(Math.random() * (20 - 15 + 1)) + 15)} = ${variable}${randomVarLoadstring}(${variable}${randomVarTableByte}); ${part2}`;
            
            const elapsed = ((performance.now() - startTime) / 1000).toFixed(4);
            return { elapsed, obfuscated };
        }

        document.getElementById("obfuscateBtn").addEventListener("click", () => {
            const statusLabel = document.getElementById("statusLabel");
            
            statusLabel.innerText = "Obfuscating...";
            statusLabel.style.color = "#c89632";

            setTimeout(() => {
                try {
                    const src = sourceInput.value;
                    const vName = document.getElementById("varInput").value;
                    const wMark = document.getElementById("wmInput").value;

                    const result = obfuscate(src, vName, wMark);
                    outputBox.value = result.obfuscated;
                    
                    outputHighlight.innerHTML = highlightLua(result.obfuscated);

                    navigator.clipboard.writeText(result.obfuscated).then(() => {
                        statusLabel.innerText = `Done! Output generated + copied to clipboard. (${result.elapsed}s)`;
                        statusLabel.style.color = "#32c864";
                    }).catch(() => {
                        statusLabel.innerText = `Done! Output generated in right panel. (${result.elapsed}s)`;
                        statusLabel.style.color = "#64b4ff";
                    });

                    showNotification("it's successfuly your script is clean!", "success");

                } catch (err) {
                    statusLabel.innerText = "Error compiling obfuscation code.";
                    statusLabel.style.color = "#c83232";
                    showNotification("Error compiling obfuscation code.", "error");
                    console.error(err);
                }
            }, 100);
        });

        document.getElementById("copyBtn").addEventListener("click", () => {
            const statusLabel = document.getElementById("statusLabel");
            if (outputBox.value.trim() !== "") {
                navigator.clipboard.writeText(outputBox.value).then(() => {
                    statusLabel.innerText = "Output copied to clipboard manually!";
                    statusLabel.style.color = "#32c864";
                    showNotification("Copied to clipboard!", "success");
                });
            }
        });
    </script>
</body>
</html>
